<!DOCTYPE html>
<html>
  <head>
    <meta charset="UTF-8" />
    <title><%= title || "Niramoy OTP" %></title>
  </head>
  <body
    style="
      margin: 0;
      padding: 20px;
      font-family: Arial, sans-serif;
      background-color: #f4f7f6;
      color: #1a1a1a;
    "
  >
    <div
      style="
        max-width: 500px;
        margin: 0 auto;
        background: #ffffff;
        padding: 30px;
        border-radius: 8px;
        border: 1px solid #e5e7eb;
      "
    >
      <!-- Header -->
      <h2
        style="
          margin-top: 0;
          color: #0f766e;
          border-bottom: 1px solid #e5e7eb;
          padding-bottom: 15px;
        "
      >
        Niramoy
      </h2>

      <!-- Greeting & Instruction -->
      <p style="font-size: 16px">Hi <strong><%= name %></strong>,</p>
      <p style="font-size: 16px; line-height: 1.5">
        Use the code below to <%= purpose || "complete your request" %>. This
        code expires in <strong><%= expiresIn || "2 minutes" %></strong>.
      </p>

      <!-- OTP Box -->
      <div style="text-align: center; margin: 30px 0">
        <span
          style="
            font-size: 32px;
            font-weight: bold;
            letter-spacing: 8px;
            color: #0f766e;
            background: #ecfeff;
            padding: 15px 24px;
            border-radius: 8px;
            display: inline-block;
          "
        >
          <%= otp %>
        </span>
      </div>

      <!-- Footer Notes -->
      <p
        style="
          font-size: 14px;
          color: #6b7280;
          line-height: 1.5;
          margin-bottom: 0;
        "
      >
        For your security, do not share this code. If you didn't request this,
        you can safely ignore this email.
      </p>
    </div>
  </body>
</html>
