model OAuthCode {
  id           String   @id @default(uuid())
  code         String   @unique
  userId       String   @unique
  token        String
  accessToken  String
  refreshToken String
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([code])
}
